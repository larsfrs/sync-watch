{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "core:tray:allow-new",
    "store:default",
    "dialog:default",
    "dialog:allow-open",
    "core:window:allow-hide"
  ]
}
